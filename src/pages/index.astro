---
import LandingPage from '../components/LandingPage';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Martis — The Laravel Admin Engine. React-first. Resource-driven. Override-first." />
    <meta property="og:title" content="Martis — Laravel Admin Engine" />
    <meta property="og:description" content="A modern admin engine for Laravel. React-first. Resource-driven. Override-first." />
    <meta property="og:image" content="/og-image.png" />
    <title>Martis — Laravel Admin Engine</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body { background: #020817; }
      img { max-width: 100%; }
      @media (max-width: 768px) {
        .hero-grid { grid-template-columns: 1fr !important; }
        .feat-grid { grid-template-columns: 1fr !important; }
        .phil-grid { grid-template-columns: 1fr !important; }
        .parity-grid { grid-template-columns: 1fr !important; }
      }
    </style>
  </head>
  <body>
    <LandingPage client:load />
  </body>
</html>
